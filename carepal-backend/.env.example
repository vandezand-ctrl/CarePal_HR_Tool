# Copy to .env.local and fill in values for local development.

# Server
PORT=4000
NODE_ENV=development

# Database (decide Stage 1: SQLite file path OR MySQL connection string)
# DATABASE_URL=sqlite:./data/carepal.sqlite
# DATABASE_URL=mysql://root:password@localhost:3306/carepal

# Mock auth (dev only — replaced by Google OAuth in production)
# Frontend sets this header; middleware reads it
# No secret needed for mock auth

# AWS S3 (document storage)
AWS_S3_BUCKET=carepal-hrms
AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=      # set in .env.local
# AWS_SECRET_ACCESS_KEY=  # set in .env.local
