{
  "name": "carepal-backend",
  "version": "0.1.0",
  "description": "Backend API for CarePal HR Admin tool",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').copyFileSync('src/openapi.yaml','dist/openapi.yaml')\"",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "migrate": "knex --knexfile knexfile.js migrate:latest",
    "seed": "knex --knexfile knexfile.js seed:run",
    "db:reset": "node -e \"try{require('fs').unlinkSync('data/carepal.sqlite')}catch{}\" && knex --knexfile knexfile.js migrate:latest && knex --knexfile knexfile.js seed:run",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "ical-generator": "^10.2.0",
    "knex": "^3.2.9",
    "multer": "^2.1.1",
    "mysql2": "^3.22.0",
    "pdf-parse": "^2.4.5",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/helmet": "^0.0.48",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
